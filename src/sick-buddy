def cmd_template(args):
    """Generate a leave message template"""
    if not args:
        print("Usage: sick-buddy template <formal|casual|brief> [company|school]")
        print("Example: sick-buddy template formal company")
        print("         sick-buddy template casual school")
        sys.exit(1)
    
    style = args[0]
    if style not in TEMPLATES:
        print(f"❌ 未知风格: {style}")
        print(f"   可选: {', '.join(TEMPLATES.keys())}")
        sys.exit(1)
    
    scene = args[1] if len(args) > 1 else "company"
    if scene not in TEMPLATES[style]:
        print(f"❌ 未知场景: {scene}")
        print(f"   可选: {', '.join(TEMPLATES[style].keys())}")
        sys.exit(1)
    
    # Load profile for auto-fill
    profile = load_profile()
    
    template = TEMPLATES[style][scene]
    
    # Auto-fill from profile where possible
    condition = ""
    if profile["conditions"]:
        condition = profile["conditions"][-1]["name"]
    
    # Show template with placeholders
    print("📝 请假模板：")
    print("─" * 40)
    print(template)
    print("─" * 40)
    print()
    print("📋 占位符说明：")
    placeholders = set()
    import re
    for match in re.finditer(r'\{([^}]+)\}', template):
        placeholders.add(match.group(1))
    
    for p in sorted(placeholders):
        auto = ""
        if p == "病症" and condition:
            auto = f" → 自动填入：{condition}"
        elif p == "天数" and profile["conditions"]:
            auto = " → 请根据实际填写"
        print(f"   {{{p}}}{auto}")
    print()
    print("💡 提示：让AI帮你自动填写，直接说'帮我生成请假消息'即可")

def main():
    if len(sys.argv) < 2:
        print("🤒 SickBuddy — 生病管理助手")
        print()
        print("Commands:")
        print("  start <condition>    开始记录病症")
        print("  log <status>         记录今日状态")
        print("  symptoms <s1> <s2>   添加症状")
        print("  confirm <condition>  确认病症")
        print("  suggest <days>       根据天数推荐病症")
        print("  template <style> [scene]  生成请假模板")
        print("  set <key> <value>    设置信息 (city/workplace/system)")
        print("  status               查看当前状态")
        print("  history              查看历史记录")
        print("  clear                清除所有记录")
        sys.exit(0)
    
    cmd = sys.argv[1]
    args = sys.argv[2:]
    
    commands = {
        "start": cmd_start,
        "log": cmd_log,
        "status": lambda a: cmd_status(),
        "set": cmd_set,
        "confirm": cmd_confirm,
        "symptoms": cmd_symptoms,
        "suggest": cmd_suggest,
        "template": cmd_template,
        "clear": lambda a: cmd_clear(),
        "history": lambda a: cmd_history(),
    }
    
    if cmd in commands:
        commands[cmd](args)
    else:
        print(f"❌ 未知命令：{cmd}")
        print("   运行 sick-buddy 查看帮助")

if __name__ == "__main__":
    main()
