#!/usr/bin/env python3
"""SickBuddy - 生病管理助手 v1.3.0"""

import json
import os
import sys
import re
import subprocess
from datetime import datetime, timedelta

DATA_DIR = os.path.expanduser("~/.openclaw/workspace/sick-buddy-data")
PROFILE_FILE = os.path.join(DATA_DIR, "profile.json")
LOG_FILE = os.path.join(DATA_DIR, "daily-log.json")
MEDICINE_FILE = os.path.join(DATA_DIR, "medicines.json")
RECOVERY_FILE = os.path.join(DATA_DIR, "recovery.json")

# ── 基础 I/O ──

def ensure_data_dir():
    os.makedirs(DATA_DIR, exist_ok=True)

def load_json(filepath, default):
    ensure_data_dir()
    if os.path.exists(filepath):
        with open(filepath) as f:
            return json.load(f)
    return default

def save_json(filepath, data):
    ensure_data_dir()
    with open(filepath, "w") as f:
        json.dump(data, f, ensure_ascii=False, indent=2)

def load_profile():
    return load_json(PROFILE_FILE, {"conditions": [], "created_at": None, "city": None, "workplace": None})

def save_profile(profile):
    save_json(PROFILE_FILE, profile)

def load_log():
    return load_json(LOG_FILE, {"entries": []})

def save_log(log):
    save_json(LOG_FILE, log)

def load_medicines():
    return load_json(MEDICINE_FILE, {"medicines": []})

def save_medicines(data):
    save_json(MEDICINE_FILE, data)

def load_recovery():
    return load_json(RECOVERY_FILE, {"scores": []})

def save_recovery(data):
    save_json(RECOVERY_FILE, data)

# ── 原有命令 ──

def cmd_start(args):
    """Start tracking a condition"""
    if not args:
        print("Usage: sick-buddy start <condition>")
        print("Example: sick-buddy start 感冒")
        sys.exit(1)
    
    condition_name = " ".join(args)
    profile = load_profile()
    
    new_condition = {
        "name": condition_name,
        "start_date": datetime.now().strftime("%Y-%m-%d"),
        "start_time": datetime.now().strftime("%H:%M"),
        "confirmed": False,
        "symptoms": [],
        "day": 1
    }
    
    profile["conditions"].append(new_condition)
    if not profile["created_at"]:
        profile["created_at"] = datetime.now().isoformat()
    
    save_profile(profile)
    print(f"✅ 已记录：{condition_name}")
    print(f"📅 开始日期：{new_condition['start_date']}")
    
    # Feature C: 自动查天气+流行病
    city = profile.get("city")
    if city:
        print()
        print_weather_and_epidemic(city)
    else:
        print("💡 设置城市可自动查询当地天气和流行病：sick-buddy set city <城市名>")

def cmd_log(args):
    """Log today's status"""
    if not args:
        print("Usage: sick-buddy log <status>")
        sys.exit(1)
    
    profile = load_profile()
    if not profile["conditions"]:
        print("❌ 还没有记录病症，先运行 sick-buddy start <病症>")
        sys.exit(1)
    
    status = " ".join(args)
    log = load_log()
    
    entry = {
        "date": datetime.now().strftime("%Y-%m-%d"),
        "time": datetime.now().strftime("%H:%M"),
        "status": status,
        "conditions": [c["name"] for c in profile["conditions"]]
    }
    
    log["entries"].append(entry)
    save_log(log)
    print(f"✅ 已记录今日状态：{status}")

