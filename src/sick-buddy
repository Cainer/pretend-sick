        "conflicts": [],
        "warning": "流感特效药，48小时内服用效果最佳",
    },
}

def normalize_drug_name(name):
    """标准化药物名称，匹配成分"""
    name_lower = name.lower()
    for ingredient, info in DRUG_CONFLICTS.items():
        if ingredient in name_lower or ingredient.lower() in name_lower:
            return ingredient
        for alias in info.get("alias", []):
            if alias.lower() in name_lower:
                return ingredient
    return None

def check_drug_conflicts(new_drug, existing_medicines):
    """检查新药物与已有药物的冲突"""
    warnings = []
    new_ingredient = normalize_drug_name(new_drug)
    
    if not new_ingredient:
        return warnings
    
    new_info = DRUG_CONFLICTS.get(new_ingredient, {})
    
    # 自身警告
    if "warning" in new_info:
        warnings.append(f"⚠️ {new_ingredient}：{new_info['warning']}")
    
    # 与已有药物冲突
    for med in existing_medicines:
        if med.get("stopped"):
            continue
        existing_ingredient = normalize_drug_name(med["name"])
        if not existing_ingredient:
            continue
        
        # 检查冲突列表
        conflicts = new_info.get("conflicts", [])
        if existing_ingredient in conflicts or existing_ingredient == new_ingredient:
            warnings.append(f"🔴 冲突：{new_ingredient} 与 {existing_ingredient}（{med['name']}）存在冲突！")
        
        # 双重检查反向
        existing_info = DRUG_CONFLICTS.get(existing_ingredient, {})
        if new_ingredient in existing_info.get("conflicts", []):
            warnings.append(f"🔴 冲突：{existing_ingredient}（{med['name']}）与 {new_ingredient} 存在冲突！")
    
    return warnings

def cmd_medicine(args):
    """用药管理"""
    if not args:
        print("💊 用药管理命令：")
        print("  medicine add <药名> <剂量> <频次>  添加用药")
        print("  medicine list                     查看当前用药")
        print("  medicine stop <药名>              停用药物")
        print("  medicine check <药名>             检查冲突")
        print()
        print("  Example: sick-buddy medicine add 泰诺 1粒 每日3次")
        print("           sick-buddy medicine check 布洛芬")
        return
    
    subcmd = args[0]
    sub_args = args[1:]
    
    if subcmd == "add":
        if len(sub_args) < 3:
            print("Usage: sick-buddy medicine add <药名> <剂量> <频次>")
            print("Example: sick-buddy medicine add 泰诺 1粒 每日3次")
            sys.exit(1)
        
        name = sub_args[0]
        dosage = sub_args[1]
        frequency = " ".join(sub_args[2:])
        
        med_data = load_medicines()
        
        # 冲突检查
        warnings = check_drug_conflicts(name, med_data["medicines"])
        
        new_med = {
            "name": name,
            "dosage": dosage,
            "frequency": frequency,
            "started": datetime.now().strftime("%Y-%m-%d %H:%M"),
            "stopped": None,
        }
        
        med_data["medicines"].append(new_med)
        save_medicines(med_data)
        
        print(f"✅ 已添加用药：{name} {dosage} {frequency}")
        if warnings:
            print()
            for w in warnings:
                print(f"   {w}")
    
    elif subcmd == "list":
        med_data = load_medicines()
        if not med_data["medicines"]:
            print("📋 当前没有用药记录")
            return
        
        print("💊 当前用药：\n")
        active = [m for m in med_data["medicines"] if not m.get("stopped")]
        stopped = [m for m in med_data["medicines"] if m.get("stopped")]
        
        if active:
            for i, m in enumerate(active):
                ingredient = normalize_drug_name(m["name"])
                ingredient_str = f"（{ingredient}）" if ingredient else ""
                print(f"   ✅ {m['name']}{ingredient_str}")
                print(f"      {m['dosage']}，{m['frequency']}")
                print(f"      开始：{m['started']}")
                print()
        
        if stopped:
            print("   已停用：")
            for m in stopped:
                print(f"   ❌ {m['name']} — 停用于 {m['stopped']}")
            print()
    
    elif subcmd == "stop":
        if not sub_args:
            print("Usage: sick-buddy medicine stop <药名>")
            sys.exit(1)
        
        name = " ".join(sub_args)
        med_data = load_medicines()
        found = False
        
        for m in med_data["medicines"]:
            if name in m["name"] or m["name"] in name:
                if not m.get("stopped"):
                    m["stopped"] = datetime.now().strftime("%Y-%m-%d")
                    found = True
                    print(f"✅ 已停用：{m['name']}")
        
        if found:
            save_medicines(med_data)
        else:
            print(f"❌ 未找到正在使用的药物：{name}")
    
    elif subcmd == "check":
        if not sub_args:
            print("Usage: sick-buddy medicine check <药名>")
            sys.exit(1)
        
        name = " ".join(sub_args)
        med_data = load_medicines()
        
        print(f"🔍 检查 {name} 的药物冲突...\n")
        
        ingredient = normalize_drug_name(name)
        if ingredient:
            info = DRUG_CONFLICTS.get(ingredient, {})
            print(f"   识别成分：{ingredient}")
            if "warning" in info:
                print(f"   ⚠️ 注意：{info['warning']}")
        
        warnings = check_drug_conflicts(name, med_data["medicines"])
        if warnings:
            for w in warnings:
                print(f"   {w}")
        else:
            print("   ✅ 未发现与当前用药的冲突")
    
    else:
        print(f"❌ 未知子命令：{subcmd}")
        print("   可用: add, list, stop, check")

# ── Feature B: 恢复进度追踪 ──

RECOVERY_ADVICE = {
    range(0, 3): "严重不适，建议就医。多休息、多补水。",
    range(3, 5): "状态较差，继续休息。按时服药，注意观察。",
    range(5, 7): "正在恢复中。保持休息，可以适当活动。",
    range(7, 9): "接近恢复。可以尝试轻度工作，注意不要劳累。",
    range(9, 11): "基本恢复！可以正常活动。",
}

def get_recovery_advice(score):
    """根据恢复评分给出建议"""
    for score_range, advice in RECOVERY_ADVICE.items():
        if score in score_range:
            return advice
    return "继续观察。"

def cmd_recover(args):
    """恢复进度追踪"""
    if not args:
        print("📊 恢复追踪命令：")
        print("  recover score <1-10>    记录今日恢复评分")
        print("  recover chart           查看恢复曲线")
        print("  recover advise          获取恢复建议")
        print()
        print("  评分标准：1=非常差，5=一半一半，10=完全恢复")
        return
    
    subcmd = args[0]
    sub_args = args[1:]
    
    if subcmd == "score":
        if not sub_args:
            print("Usage: sick-buddy recover score <1-10> [备注]")
            sys.exit(1)
        
        try:
            score = int(sub_args[0])
        except ValueError:
            print("❌ 评分必须是1-10的数字")
            sys.exit(1)
        
        if score < 1 or score > 10:
            print("❌ 评分范围：1-10")
            sys.exit(1)
        
        note = " ".join(sub_args[1:]) if len(sub_args) > 1 else ""
        
        rec_data = load_recovery()
        entry = {
            "date": datetime.now().strftime("%Y-%m-%d"),
            "time": datetime.now().strftime("%H:%M"),
            "score": score,
            "note": note,
        }
        rec_data["scores"].append(entry)
        save_recovery(rec_data)
        
        advice = get_recovery_advice(score)
        
        # 趋势分析
        trend = ""
        if len(rec_data["scores"]) >= 2:
            prev = rec_data["scores"][-2]["score"]
            diff = score - prev
            if diff > 0:
                trend = f" 📈 比上次提升{diff}分"
            elif diff < 0:
                trend = f" 📉 比上次下降{abs(diff)}分"
            else:
                trend = " ➡️ 与上次持平"
        
        print(f"✅ 已记录恢复评分：{score}/10{trend}")
        print(f"   💡 {advice}")
        
        # 低分提醒
        if score <= 3 and len(rec_data["scores"]) >= 3:
            recent_3 = [s["score"] for s in rec_data["scores"][-3:]]
            if all(s <= 3 for s in recent_3):
                print(f"   ⚠️ 连续3天评分≤3，建议就医复查")
    
    elif subcmd == "chart":
        rec_data = load_recovery()
        if not rec_data["scores"]:
            print("📋 还没有恢复记录")
            return
        
        print("📊 恢复曲线：\n")
        
        max_score = max(s["score"] for s in rec_data["scores"])
        
        for entry in rec_data["scores"][-14:]:  # 最近14天
            bar_len = entry["score"]
            bar = "█" * bar_len + "░" * (10 - bar_len)
            note_str = f" {entry['note']}" if entry.get("note") else ""
            print(f"   {entry['date']} [{bar}] {entry['score']}/10{note_str}")
        
        if len(rec_data["scores"]) >= 3:
            avg_3 = sum(s["score"] for s in rec_data["scores"][-3:]) / 3
            print(f"\n   近3天平均：{avg_3:.1f}/10")
            
            first = rec_data["scores"][0]["score"]
            latest = rec_data["scores"][-1]["score"]
            if latest > first:
                print(f"   总体趋势：📈 上升（从{first}到{latest}）")
            elif latest < first:
                print(f"   总体趋势：📉 下降（从{first}到{latest}），建议就医")
            else:
                print(f"   总体趋势：➡️ 持平")
    
    elif subcmd == "advise":
        rec_data = load_recovery()
        if not rec_data["scores"]:
            print("📋 还没有恢复记录，先评分：sick-buddy recover score <1-10>")
            return
        
        latest = rec_data["scores"][-1]
        advice = get_recovery_advice(latest["score"])
        
        print(f"💡 恢复建议（当前评分：{latest['score']}/10）\n")
        print(f"   {advice}")
        
        # 用药提醒
        med_data = load_medicines()
        active_meds = [m for m in med_data["medicines"] if not m.get("stopped")]
        if active_meds:
            print(f"\n   💊 当前用药：")
            for m in active_meds:
                print(f"      {m['name']} — {m['frequency']}")
        
        # 复诊建议
        profile = load_profile()
        if profile["conditions"]:
            for c in profile["conditions"]:
                start = datetime.strptime(c["start_date"], "%Y-%m-%d")
                days = (datetime.now() - start).days + 1
                if days >= 7 and latest["score"] <= 5:
                    print(f"\n   ⚠️ {c['name']}已{days}天，恢复评分仍≤5，建议复诊")
    
    else:
        print(f"❌ 未知子命令：{subcmd}")
        print("   可用: score, chart, advise")

# ── Feature C: 天气+流行病查询 ──

def get_weather(city):
    """通过 curl wttr.in 获取天气"""
    try:
        result = subprocess.run(
            ["curl", "-s", f"wttr.in/{city}?format=%C+%t+%h+%w&lang=zh"],
            capture_output=True, text=True, timeout=10
        )
        if result.returncode == 0 and result.stdout.strip():
            return result.stdout.strip()
    except Exception:
        pass
    return None

def get_epidemic_info(city):
    """获取流行病信息（基于当前月份的知识库匹配）"""
    month = datetime.now().month
    
    # 季节性流行病参考
    epidemic_db = {
        "春季": {
            "months": [3, 4, 5],
            "diseases": ["流感", "花粉过敏", "感冒", "咽炎"],
            "tips": "春季气温变化大，注意增减衣物",
        },
        "夏季": {
            "months": [6, 7, 8],
            "diseases": ["肠胃炎", "中暑", "食物中毒", "登革热"],
            "tips": "夏季注意饮食卫生，南方注意防蚊",
        },
        "秋季": {
            "months": [9, 10, 11],
            "diseases": ["感冒", "过敏", "咽炎", "支原体"],
            "tips": "秋季干燥，注意补水和呼吸道保护",
        },
        "冬季": {
            "months": [12, 1, 2],
            "diseases": ["流感", "感冒", "支原体", "新冠"],
            "tips": "冬季流感高发，注意保暖和室内通风",
        },
    }
    
    season = None
    for s, info in epidemic_db.items():
        if month in info["months"]:
            season = s
            return {
                "season": season,
                "diseases": info["diseases"],
