def cmd_set(args):
    """Set profile info"""
    if len(args) < 2:
        print("Usage: sick-buddy set <key> <value>")
        print("Keys: city, workplace, system")
        sys.exit(1)
    
    key, value = args[0], " ".join(args[1:])
    profile = load_profile()
    profile[key] = value
    save_profile(profile)
    print(f"✅ 已设置 {key} = {value}")

def cmd_confirm(args):
    """Confirm a condition"""
    if not args:
        print("Usage: sick-buddy confirm <condition_name>")
        sys.exit(1)
    
    name = " ".join(args)
    profile = load_profile()
    for c in profile["conditions"]:
        if name in c["name"] or c["name"] in name:
            c["confirmed"] = True
            save_profile(profile)
            print(f"✅ 已确认病症：{c['name']}")
            return
    print(f"❌ 未找到病症：{name}")

def cmd_symptoms(args):
    """Add symptoms to current condition"""
    if not args:
        print("Usage: sick-buddy symptoms <symptom1> <symptom2> ...")
        sys.exit(1)
    
    profile = load_profile()
    if not profile["conditions"]:
        print("❌ 还没有记录病症")
        sys.exit(1)
    
    for c in profile["conditions"]:
        if not c["confirmed"]:
            for s in args:
                if s not in c["symptoms"]:
                    c["symptoms"].append(s)
            save_profile(profile)
            print(f"✅ 已添加症状：{', '.join(args)}")
            print(f"   当前症状：{', '.join(c['symptoms'])}")
            return
    
    c = profile["conditions"][-1]
    for s in args:
        if s not in c["symptoms"]:
            c["symptoms"].append(s)
    save_profile(profile)
    print(f"✅ 已添加症状：{', '.join(args)}")

def cmd_clear():
    """Clear all data"""
    profile = load_profile()
    if profile["conditions"]:
        for f in [PROFILE_FILE, LOG_FILE, MEDICINE_FILE, RECOVERY_FILE]:
            if os.path.exists(f):
                os.remove(f)
        print("✅ 已清除所有记录（含用药和恢复数据）")
    else:
