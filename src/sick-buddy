def cmd_suggest(args):
    """Suggest conditions based on desired leave days"""
    if not args:
        print("Usage: sick-buddy suggest <days>")
        print("Example: sick-buddy suggest 3")
        sys.exit(1)
    
    try:
        days = int(args[0])
    except ValueError:
        print("❌ 天数必须是数字")
        sys.exit(1)
    
    if days < 1 or days > 30:
        print("❌ 天数范围: 1-30")
        sys.exit(1)
    
    # Find the closest key
    keys = sorted(SUGGESTIONS.keys())
    closest = min(keys, key=lambda k: abs(k - days))
    
    print(f"🎯 想请 {days} 天假，推荐以下病症：")
    print(f"   （基于 {closest} 天病程匹配）\n")
    
    for i, s in enumerate(SUGGESTIONS[closest], 1):
        print(f"   {i}. {s['name']} [{s['severity']}]")
        print(f"      特征：{s['match']}")
        print()
    
    print("💡 提示：这只是参考，请根据实际症状选择。")
    print("   确定后运行 sick-buddy start <病症名>")

